    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/api/investigations/anomaly",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{}",
        "options": {
          "redirect": {
            "redirect": {}
          }
        }
      },
      "id": "trigger-anomaly-scan",
      "name": "Trigger Anomaly-Scan",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 320],
      "notes": "Nach jedem Sync läuft der Anomalie-Detektor auf den frisch\nimportierten Daten. Neue Empfehlungen tauchen automatisch im\nDashboard auf — dedup-geschützt durch _pending_duplicate_exists()."
    }
  ],
  "connections": {
