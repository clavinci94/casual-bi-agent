    "make shopify-sync-incremental": {
      "main": [
        [
          {
            "node": "Trigger Anomaly-Scan",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
