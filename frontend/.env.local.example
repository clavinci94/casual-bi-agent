# --------------------------------------------------------------------------
# LOCAL DEVELOPMENT — copy to .env.local and fill in.
# For production-on-Vercel: set the same keys in the Vercel dashboard
# (Settings → Environment Variables). See infra/deploy.md.
# --------------------------------------------------------------------------

# URL of the FastAPI backend. Server components use this for SSR fetches.
# Use 127.0.0.1 (not localhost) so the Node loopback resolver hits IPv4
# reliably. Production: https://biq-api.onrender.com (or your Render URL).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# --------------------------------------------------------------------------
# AUTH0 SSO (v4 SDK) — leave AUTH0_* blank to keep auth disabled locally;
# any non-empty AUTH0_ISSUER_BASE_URL turns it on. See docs/sso-setup.md.
# --------------------------------------------------------------------------

# 32+ random bytes — generate with: openssl rand -hex 32
AUTH0_SECRET=

# Where the app is reached. Local: http://localhost:3000.
# Production on Vercel: https://<your-project>.vercel.app (or custom domain).
AUTH0_BASE_URL=http://localhost:3000

# Auth0 tenant base URL — e.g. https://causal-bi.eu.auth0.com (no trailing /)
AUTH0_ISSUER_BASE_URL=

# From Auth0 Dashboard → Applications → <your app> → Settings
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# API audience — must match the backend's BIQ_JWT_AUDIENCE exactly and
# must exist as an API in Auth0 Dashboard → APIs.
AUTH0_AUDIENCE=https://api.causal-bi.local

# OIDC scopes requested for the access-token + ID-token
AUTH0_SCOPE=openid profile email
