# Database
# Local Docker (default for development):
DATABASE_URL=postgresql+psycopg://causalbi:causalbi@localhost:5433/causalbi
# Neon (production / deploy):
# DATABASE_URL=postgresql+psycopg://user:pass@host.neon.tech/dbname?sslmode=require

# LLM providers
ANTHROPIC_API_KEY=
# Admin API key for /v1/organizations/* (Console → Admin Keys). Optional —
# leave empty to disable the dashboard's /settings page. Never the same as
# ANTHROPIC_API_KEY; the admin key has org-wide read access.
ANTHROPIC_ADMIN_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# R CausalImpact service (docker-compose r-causal)
R_BASE_URL=http://localhost:8765

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# External intelligence — used by the Markt-Radar page and the
# investigator's external tools. All are optional; tools degrade
# gracefully if a key is missing.
TAVILY_API_KEY=
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=

# Shopify ETL source. See docs/shopify-setup.md for the 5-minute
# walkthrough (Partner account → Dev-Store → Custom App → token).
# Both must be set for `make shopify-sync` to run.
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_API_TOKEN=

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Simulation
SIMULATION_SEED=42
BRL_TO_CHF=0.16

# App
APP_ENV=local
LOG_LEVEL=info

# When set, the HTTP API requires X-API-Key: <value> on /api/*.
# Unset (dev) = open. Set in Render env-group for production.
BIQ_API_KEY=

# Auth-Modus für /api/* — siehe docs/sso-setup.md
#   api_key     (default)  X-API-Key Header gegen BIQ_API_KEY
#   bearer_jwt              Authorization: Bearer <jwt>, JWKS-validiert
#   disabled                keine Auth (nur Dev)
BIQ_AUTH_MODE=api_key
# Wenn bearer_jwt: JWKS-URL deines IdP (Auth0/Okta/Azure AD/Keycloak)
BIQ_JWT_JWKS_URL=
BIQ_JWT_ISSUER=
BIQ_JWT_AUDIENCE=
