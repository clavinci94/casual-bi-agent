# Database
# Local Docker (default for development):
DATABASE_URL=postgresql+psycopg://causalbi:causalbi@localhost:5433/causalbi
# Neon (production / deploy):
# DATABASE_URL=postgresql+psycopg://user:pass@host.neon.tech/dbname?sslmode=require

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
